# Normalize line endings to LF on checkout across all platforms.
# This prevents golden test failures on Windows where git may check
# out text files with CRLF, causing byte-for-byte diff against
# LF-rendered terminal output.

* text=auto

*.golden text eol=lf
*.go     text eol=lf
*.yaml   text eol=lf
*.yml    text eol=lf
*.toml   text eol=lf
*.sh     text eol=lf
*.md     text eol=lf
*.json   text eol=lf
*.jsonl  text eol=lf
